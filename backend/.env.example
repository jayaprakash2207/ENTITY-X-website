# ── Server ──
PORT=4000
NODE_ENV=development

# ── CORS — comma-separated list of allowed origins ──
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://entityx.app,https://www.entityx.app

# ── Admin API Key ──
# Generate a strong random key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=change_me_to_a_strong_random_key

# ── GitHub Token (optional, increases API rate limit from 60 to 5000 req/hr) ──
# GITHUB_TOKEN=ghp_your_token_here

# ── SMTP Email (optional — if not set, emails are logged to console) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password
# EMAIL_FROM=Entity X <noreply@entityx.app>
# EMAIL_NOTIFY=jayaprakash@youremail.com
